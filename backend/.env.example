# Copy this file to .env and fill in your real values.
# For Gmail: enable 2-Step Verification and create an App Password.
# https://myaccount.google.com/apppasswords

PORT=3000

# Email where enquiry notifications are sent
NOTIFY_EMAIL=radhikaagenciesddun@gmail.com

# SMTP settings (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Admin login for the enquiry panel (change these!)
ADMIN_USER=admin
ADMIN_PASS=radhika2024
# Secret used to sign the session token (use a long random string)
ADMIN_SECRET=change-this-to-a-long-random-string

# ---------- Database ----------
# Leave DB_TYPE unset (or set to "sqlite") to use a local SQLite file (submissions.db).
# On GoDaddy cPanel, create a MySQL database + user and set DB_TYPE=mysql with these:
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=your_cpanel_db_user
# DB_PASS=your_db_password
# DB_NAME=your_database_name
# (SQLite users can ignore the DB_* vars above.)
